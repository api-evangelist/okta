        {
          "dest": "orgSetting",
          "self": true
        }
      ],
      "operationId": "updateOrgSetting"
    }
  ],
  "x-okta-operations": [
    {
      "alias": "partialUpdate",
      "arguments": [
        {
          "dest": "orgSetting",
          "self": true
        }
      ],
      "operationId": "partialUpdateOrgSetting"
    },
    {
      "alias": "getContactTypes",
      "operationId": "getOrgContactTypes"
